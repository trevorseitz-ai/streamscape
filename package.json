{
  "name": "reeldive",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "android:install-only": "expo run:android --no-bundler",
    "adb:reverse": "adb reverse tcp:8081 tcp:8081",
    "adb:open-url": "node ./scripts/adb-open-url.mjs",
    "android:release": "cd android && ./gradlew assembleRelease",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "sync:stream-finder": "npx tsx scripts/stream-finder-sync.ts",
    "inspect:stream-finder-payload": "npx tsx scripts/inspect-payload.ts",
    "audit:stream-finder-providers": "npx tsx scripts/audit-providers.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~55.0.17",
    "expo-constants": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-screen-orientation": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-youtube-iframe": "^2.4.1",
    "zod": "^4.3.6"
  },
  "private": true,
  "devDependencies": {
    "dotenv": "^16.4.7",
    "@types/react": "~19.2.10",
    "@vercel/node": "^3.2.29",
    "typescript": "~5.9.2"
  }
}
