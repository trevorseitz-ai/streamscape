# ==========================================
# Expo app (bundled — EXPO_PUBLIC_* is exposed to the client)
# ==========================================
# RapidAPI — Film & Show / top lists for Discover prefetch (Film & Show ratings hub)
# Subscribe on RapidAPI Hub and set host to the API’s X-RapidAPI-Host value (e.g. film-show-ratings.p.rapidapi.com).
EXPO_PUBLIC_RAPIDAPI_KEY=
EXPO_PUBLIC_RAPIDAPI_HOST=
# Optional: default is /top-100-items (Film & Show ratings “Top 100 items”).
# EXPO_PUBLIC_RAPIDAPI_FILMSHOW_TOP_PATH=/top-100-items

# Supabase project URL and anon key for the running app (Web / TV / native).
# Use the anon key from Supabase Dashboard → Project Settings → API.
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ==========================================
# Node scripts only (migrate-waitlist, sync-schema — NEVER bundle or commit real values)
# ==========================================
# Same project URL as above; used by scripts that load .env via dotenv (not EXPO_PUBLIC_*).
SUPABASE_URL=your_supabase_url_here

# Service role key — bypasses RLS. Only for trusted local/CI scripts, never for the Expo client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
